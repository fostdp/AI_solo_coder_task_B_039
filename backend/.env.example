# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lng_monitoring

# Modbus TCP配置
MODBUS_HOST=localhost
MODBUS_PORT=502
MODBUS_SLAVE=1
MODBUS_INTERVAL=30
TANK_COUNT=4
LAYERS=5
THERMO_PER_LAYER=8
DENSITY_METERS=3

# OPC UA配置
OPCUA_ENDPOINT=opc.tcp://localhost:4840
OPCUA_NODE=ns=2;s=Alarm

# API服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 告警配置
TEMP_DIFF_THRESHOLD=8.0
DENSITY_DIFF_THRESHOLD=2.0
PRESSURE_THRESHOLD_PCT=90.0

# 预测模型配置
PREDICTION_INTERVAL=300
GRID_POINTS=50
TIME_STEPS=1000
STABILITY_THRESHOLD=0.5
